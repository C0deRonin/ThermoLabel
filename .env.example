# Environment Configuration

# Database
DATABASE_URL=postgresql://thermolabel_user:thermolabel_password@postgres:5432/thermolabel_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=thermolabel_db
DB_USER=thermolabel_user
DB_PASSWORD=thermolabel_password

# Frontend API
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://thermolabel-backend:8000

# Application
NODE_ENV=development
DEBUG=false
RUNNING_IN_DOCKER=1

# Docker volumes (local development)
POSTGRES_DATA_PATH=./.docker/postgres-data

# For production/remote deployment, set these:
# POSTGRES_DATA_PATH=/var/lib/postgresql/data  (external volume)
# DB_HOST=your-database-server.com
# DB_PASSWORD=your-secure-password
# NEXT_PUBLIC_API_URL=https://your-domain.com/api
